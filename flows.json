    {
        "id": "anti_cheat",
        "type": "function",
        "z": "tab_iot_lab",
        "name": "Filtre Anti-Triche",
        "func": "let currentDistance = msg.payload.distance;\nlet mac = msg.payload.mac;\nmsg.mac = mac;\n\nlet history = flow.get(\"distanceHistory\") || {};\nlet lastDistance = history[mac] || currentDistance;\nlet diff = Math.abs(currentDistance - lastDistance);\n\nhistory[mac] = currentDistance;\nflow.set(\"distanceHistory\", history);\n\nif (currentDistance > 80) {\n    return [msg, null, null];\n} \nelse if (diff <= 2) {\n    return [null, msg, null];\n} \nelse {\n    return [null, null, msg];\n}",
        "outputs": 3,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 350,
        "y": 300,
        "wires": [
            [
                "timer_absence"
            ],
            [
                "timer_triche"
            ],
