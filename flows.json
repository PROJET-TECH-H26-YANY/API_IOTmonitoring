    {
        "id": "format_buzzer",
        "type": "function",
        "z": "tab_iot_lab",
        "name": "Format Buzzer/LED",
        "func": "var cmd = msg.payload.command;\n\n// Topic dynamique avec l'adresse MAC\nmsg.topic = \"labo/device/\" + msg.mac + \"/command\";\n\nif (cmd === \"BUZZER_ON\") {\n    msg.payload = { \"buzzer\": true };\n} else if (cmd === \"BUZZER_OFF_LED_ON\") {\n    msg.payload = { \n        \"buzzer\": false,\n        \"led\": 100\n    };\n}\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
