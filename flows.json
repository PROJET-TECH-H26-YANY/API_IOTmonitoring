    {
        "id": "format_cmd",
        "type": "function",
        "z": "tab_iot_lab",
        "name": "Format CMD",
        "func": "var cmd = msg.payload.command;\nvar name = msg.payload.student || \"\";\nvar studentId = msg.payload.studentId || \"\"; \n\n\nmsg.topic = \"labo/device/\" + msg.mac + \"/command\";\n\nvar texteEcran = \"ID: \" + studentId + \" - \" + name;\n\nif (cmd === \"LED_ON_100\") {\n    msg.payload = { \"led\": 100, \"oled\": texteEcran };\n} else if (cmd === \"LED_OFF\") {\n    msg.payload = { \"led\": 0, \"oled\": \"Au revoir\" };\n} else if (cmd === \"LED_RED_BLINK\") {\n    msg.payload = { \"led\": \"blink_red\", \"buzzer\": \"short\" };\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 710,
        "y": 80,
        "wires": [
            [
                "mqtt_out_cmd"
            ]
        ]
    },
